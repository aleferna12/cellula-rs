size_init_cells = 25
init_cell_config = 0
randgroups = false

##########################
## Evolution parameters ##
##########################

evolreg = false
groupextinction = false

## Genome mutation ##
mu = 0.05
mustd = 0.05
scatter_start = true

gompertz_alpha = 0.0
gompertz_beta = 0

#################################
### Chem. gradient parameters ###
#################################

