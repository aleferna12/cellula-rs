gradscale = 5
foodpatches = 1
maxfoodpatches = 1
foodpatchperiod = 100000
foodpatcharea = 12
foodperspot = 25
foodstart = 200000000
metabperiod = 100000
eatperiod = 10
seasonduration = 100000
seasonamplitude = 0

############
## Output ##
############

graphics = false
save_movie = true
save_movie_period = 100000
save_data_period = 100000
save_lattice_period = 100000
info_period = 10000
existing_dirs = true
replace_dirs = true

